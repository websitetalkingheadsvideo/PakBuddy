MYSQL_URL="mysql+aiomysql://REPLACE_USER:REPLACE_PASSWORD@127.0.0.1:3306/REPLACE_DB"

# Comma-separated list of origins allowed to call the API. No wildcards.
CORS_ORIGINS="https://pakbuddystore.com,https://www.pakbuddystore.com"

# Long random string. Required to read /api/fleet-inquiry.
# Generate with: openssl rand -hex 32
ADMIN_TOKEN="REPLACE_WITH_LONG_RANDOM_STRING"

# Fleet-inquiry rate limit (per IP)
FLEET_RATE_LIMIT_MAX="5"
FLEET_RATE_LIMIT_WINDOW_SECONDS="3600"
